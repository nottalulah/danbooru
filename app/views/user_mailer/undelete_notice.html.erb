<h2>Hi <%= link_to_user @user %>,</h2>

<p>
  Your <%= link_to Danbooru.config.canonical_app_name, root_url %> account has been restored. Click the link below to set your password:
</p>

<p style="margin-left: 2em">
  <%= link_to "Set password", edit_password_reset_url(user: { signed_id: @user.signed_id(purpose: :password_reset, expires_in: 30.minutes) }) %>
</p>

<p class="fineprint">
  You received this email because your account on <%= link_to Danbooru.config.canonical_app_name, root_url %> was undeleted.<br>
  This link will expire in 30 minutes.
</p>
